# Required
SESSION_SECRET=change-me-generate-with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_PASSWORD=change-me

# Who runs this instance. Both appear on the privacy page; the email also
# receives signup notifications.
OPERATOR_NAME=Your Name
OPERATOR_EMAIL=you@example.com

# Signup notifications: each verified signup emails the person's name and
# email address here. Defaults to OPERATOR_EMAIL.
# NOTIFY_EMAIL=

# Database (default: sqlite:///data/bokehbowl.db)
# DATABASE_URL=sqlite:///data/bokehbowl.db

# Cookies require HTTPS by default. Set to false only for local dev over http.
# COOKIE_SECURE=false

# Proxy hops trusted to set X-Forwarded-* headers (read by uvicorn; default
# 127.0.0.1). The compose file sets the Docker network ranges. On other
# platforms, set the address the platform's proxy connects from.
# FORWARDED_ALLOW_IPS=127.0.0.1

# The footer shows the running commit, read from .git automatically. Set this
# only where .git isn't available — e.g. GIT_COMMIT=${RAILWAY_GIT_COMMIT_SHA}
# on Railway, or =${RENDER_GIT_COMMIT} on Render.
# GIT_COMMIT=

# Email. "console" prints codes to stdout (dev). "smtp" sends real mail.
MAIL_BACKEND=console

# For MAIL_BACKEND=smtp — values below are for Cloudflare Email Service;
# any SMTPS (port 465) provider works.
# SMTP_HOST=smtp.mx.cloudflare.net
# SMTP_PORT=465
# SMTP_USERNAME=api_token
# SMTP_PASSWORD=...
# MAIL_SENDER=Bokehbowl <mail@bokehbowl.com>